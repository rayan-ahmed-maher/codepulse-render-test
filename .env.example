# =============================================================
# DeployAI — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your values.
# All API keys are required for full functionality.
# The platform will degrade gracefully if optional keys are missing.

# ── NVIDIA NIM API (SRE Diagnostics & AI LLM) ────────────────
NVIDIA_API_KEY=

# ── Supabase (Auth + Database + Storage) ──────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Deployment Platforms ──────────────────────────────────────
VERCEL_TOKEN=
NETLIFY_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
RENDER_API_KEY=

# ── Search & Intelligence ─────────────────────────────────────
SERPER_API_KEY=

# ── Domain Intelligence ───────────────────────────────────────
DOMSCAN_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=

# ── Monitoring (New Relic) ────────────────────────────────────
NEW_RELIC_LICENSE_KEY=

# ── Payments (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── GitHub (optional — higher rate limits) ────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=

# ── Sentry (Error Tracking) ───────────────────────────────────
SENTRY_DSN=

# ── PostHog (Product Analytics) ───────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── Environment ──────────────────────────────────────────────
DEPLOY_ENV=development
RENDER_OWNER_ID=tea-d7qbf068bjmc73c1dutg
